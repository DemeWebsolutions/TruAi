# TruAi Memory Gateway — token rotation ready
# Copy to .env and replace with real values (do not commit .env)

TRUAI_TOKENS=change-me-truai-1,change-me-truai-2
PHANTOM_TOKENS=change-me-phantom-1
GEMINI_TOKENS=change-me-gemini-1

# Optional: payload limits (defaults 20000)
# MAX_TEXT_CHARS=20000
# MAX_PAYLOAD_CHARS=20000

# QDRANT_URL and OLLAMA_URL are set by docker-compose for containers
