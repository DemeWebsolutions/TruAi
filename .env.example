# TruAi Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Deployment mode ────────────────────────────────────────────────────────
# Options: development | testing | production
TRUAI_DEPLOYMENT=development

# ── AI Service API Keys ────────────────────────────────────────────────────
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-openai-key...

# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...

# ── Allowed Hosts (production only) ───────────────────────────────────────
# Comma-separated list of additional allowed hostnames/IPs beyond localhost
# Only used when TRUAI_DEPLOYMENT=production
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Session & Security ────────────────────────────────────────────────────
# Session lifetime in seconds (default: 3600 = 1 hour)
# SESSION_LIFETIME=3600

# ── Optional: External API endpoint ──────────────────────────────────────
# TRUAI_API_ENDPOINT=https://api.truai.example.com
# TRUAI_API_KEY=
