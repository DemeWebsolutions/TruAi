{
  "name": "truai-electron",
  "productName": "TruAi",
  "version": "1.0.0",
  "description": "TruAi — AI-powered development assistant (Desktop)",
  "main": "main.js",
  "author": "My Deme, LLC",
  "license": "proprietary",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev":   "NODE_ENV=development electron . --inspect",
    "build": "electron-builder --mac --dir",
    "build:win": "electron-builder --win --dir",
    "build:linux": "electron-builder --linux --dir",
    "pack": "npx electron-builder --mac",
    "pack:win": "npx electron-builder --win",
    "pack:linux": "npx electron-builder --linux",
    "dist": "npx electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId":       "com.truai.desktop",
    "productName": "TruAi",
    "copyright":   "Copyright © 2025 My Deme, LLC",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "supervisor.js",
      "runtimeContract.js",
      "config.template.json",
      "dashboard.html",
      "runtime/manifest.json"
    ],
    "extraResources": [
      { "from": "../assets", "to": "assets", "filter": ["**/*"] },
      { "from": "../public", "to": "public", "filter": ["**/*"] },
      { "from": "../backend", "to": "backend", "filter": ["**/*"] },
      { "from": "../router.php", "to": "router.php" }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/AppIcon.icns",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }, { "target": "zip", "arch": ["arm64", "x64"] }],
      "extendInfo": {
        "CFBundleName": "TruAi",
        "CFBundleDisplayName": "TruAi"
      }
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "../assets/images/TruAi-icon.png"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "../assets/images/TruAi-icon.png"
    }
  }
}
