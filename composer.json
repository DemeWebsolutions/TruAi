{
    "name": "demewebsolutions/truai",
    "description": "TruAi — Super Admin Portal with ROMA Security, LSRP Recovery, and UBSAS Biometric Auth",
    "type": "project",
    "license": "proprietary",
    "homepage": "https://demewebsolutions.com",
    "authors": [
        {
            "name": "My Deme, LLC",
            "homepage": "https://demewebsolutions.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-sqlite3": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "setup": "php scripts/setup_database.php",
        "migrate": "php scripts/run_migrations.php",
        "test": "php tests/run_tests.php"
    }
}
